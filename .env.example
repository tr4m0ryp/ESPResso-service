# ESPResso Service Configuration
API_KEY=your-shared-secret-here

# Security
# Environment: "development" or "production"
# In production: docs are hidden, HMAC_SECRET is required
ENVIRONMENT=development
# Shared HMAC secret with the avelero backend for brand authorization
# Required in production; when empty, HMAC verification is skipped (dev mode)
HMAC_SECRET=
# Rate limiting: max requests per IP within the sliding window
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
# Comma-separated list of allowed CORS origins (empty = no CORS)
ALLOWED_ORIGINS=
# When true, unauthenticated /health requests get minimal status only
HEALTH_REQUIRE_AUTH=false

# NVIDIA NIM
# Single key (backward compatible):
NIM_API_KEY=your-nvidia-nim-api-key
# Multiple keys for rate-limit rotation (comma-separated, takes priority):
# NIM_API_KEYS=key1,key2,key3
NIM_MODEL_ID=moonshotai/kimi-k2-instruct
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Model artifacts
MODEL_A_PATH=artifacts/model_a.pkl
MODEL_B_PATH=artifacts/model_b.pkl
MODEL_C_PATH=artifacts/model_c.pkl

# Pipeline settings
RARITY_CONFIDENCE_THRESHOLD=0.6
MAX_BATCH_SIZE=500
NIM_CONCURRENCY_LIMIT=5

# Cache settings
CACHE_MAX_SIZE=10000
CACHE_TTL_SECONDS=86400

# Supabase (for product data fetch + result write-back)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
